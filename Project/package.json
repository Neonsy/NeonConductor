{
    "name": "neon-conductor",
    "private": true,
    "version": "0.0.1",
    "description": "AI agent manager with Kilo integration and BYOK support.",
    "homepage": "https://github.com/Neonsy/NeonConductor",
    "packageManager": "pnpm@10.31.0",
    "author": {
        "name": "Neonsy",
        "email": "118444485+Neonsy@users.noreply.github.com"
    },
    "type": "module",
    "main": "dist-electron/index.js",
    "scripts": {
        "dev": "vite",
        "generate:migrations": "tsx scripts/generate-migrations.ts",
        "check:migrations": "tsx scripts/generate-migrations.ts --check",
        "audit:agents": "tsx scripts/audit-agents-conformance.ts",
        "audit:agents:report": "tsx scripts/audit-agents-conformance.ts --report",
        "doctor:desktop": "tsx scripts/doctor-desktop.ts",
        "doctor:desktop:dev": "tsx scripts/doctor-desktop.ts --scope=development",
        "build": "pnpm run check:migrations && vite build",
        "build:win": "pnpm run build && electron-builder --win -c electron-builder.json5",
        "build:mac": "pnpm run build && electron-builder --mac --arm64 --x64 -c electron-builder.json5",
        "build:mac:arm64": "pnpm run build && electron-builder --mac --arm64 -c electron-builder.json5",
        "build:mac:x64": "pnpm run build && electron-builder --mac --x64 -c electron-builder.json5",
        "build:linux": "pnpm run build && electron-builder --linux -c electron-builder.json5",
        "publish:generic": "tsx scripts/publish.ts",
        "migrate:runtime": "tsx scripts/migrate-runtime.ts",
        "provider:catalog:drift": "tsx scripts/provider-catalog-drift-report.ts",
        "typecheck": "pnpm run check:migrations && tsr generate && tsc --noEmit -p tsconfig.renderer.json && tsc --noEmit -p tsconfig.node.json",
        "lint": "tsr generate && eslint .",
        "lint:fix": "tsr generate && eslint . --fix",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "dependencies": {
        "@radix-ui/react-slot": "^1.2.4",
        "@tanstack/ai": "^0.6.3",
        "@tanstack/ai-react": "^0.6.4",
        "@tanstack/react-form": "^1.28.5",
        "@tanstack/react-query": "^5.90.21",
        "@tanstack/react-router": "^1.166.7",
        "@tanstack/react-virtual": "^3.13.22",
        "@trpc/client": "^11.12.0",
        "@trpc/react-query": "^11.12.0",
        "@trpc/server": "^11.12.0",
        "arktype": "^2.2.0",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "electron-store": "^11.0.2",
        "electron-trpc-experimental": "1.0.0-alpha.1",
        "evlog": "^2.5.0",
        "kysely": "^0.28.11",
        "lucide-react": "^0.577.0",
        "mutative": "^1.3.0",
        "neverthrow": "^8.2.0",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "react-markdown": "^10.1.0",
        "remark-gfm": "^4.0.1",
        "remark-parse": "^11.0.0",
        "remark-stringify": "^11.0.0",
        "shiki": "^4.0.2",
        "strip-markdown": "^6.0.0",
        "tailwind-merge": "^3.5.0",
        "tiktoken": "^1.0.22",
        "unified": "^11.0.5",
        "zustand": "^5.0.11"
    },
    "devDependencies": {
        "@bufferings/eslint-plugin-neverthrow": "0.3.0",
        "@changesets/changelog-github": "^0.6.0",
        "@changesets/cli": "^2.30.0",
        "@eslint/compat": "^2.0.3",
        "@eslint/js": "^10.0.1",
        "@rolldown/plugin-babel": "^0.1.8",
        "@tailwindcss/forms": "^0.5.11",
        "@tailwindcss/vite": "^4.2.1",
        "@tanstack/devtools-vite": "^0.5.5",
        "@tanstack/eslint-plugin-query": "^5.91.4",
        "@tanstack/react-ai-devtools": "^0.2.13",
        "@tanstack/react-devtools": "^0.9.13",
        "@tanstack/react-form-devtools": "^0.2.18",
        "@tanstack/react-query-devtools": "^5.91.3",
        "@tanstack/react-router-devtools": "^1.166.7",
        "@tanstack/router-cli": "^1.166.7",
        "@tanstack/router-plugin": "^1.166.7",
        "@types/node": "^25.5.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.0",
        "@vitest/eslint-plugin": "^1.6.11",
        "babel-plugin-react-compiler": "^1.0.0",
        "dotenv": "^17.3.1",
        "electron": "^41.0.1",
        "electron-builder": "^26.8.1",
        "electron-builder-squirrel-windows": "26.8.1",
        "electron-updater": "^6.8.3",
        "eslint": "^10.0.3",
        "eslint-config-prettier": "^10.1.8",
        "eslint-import-resolver-typescript": "^4.4.4",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-jsx-a11y": "^6.10.2",
        "eslint-plugin-n": "^17.24.0",
        "eslint-plugin-no-secrets": "^2.3.3",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.0.1",
        "eslint-plugin-react-refresh": "^0.5.2",
        "eslint-plugin-security": "^4.0.0",
        "globals": "^17.4.0",
        "prettier": "^3.8.1",
        "prettier-plugin-tailwindcss": "^0.7.2",
        "tailwind-clamp": "^4.5.0",
        "tailwindcss": "^4.2.1",
        "tsx": "^4.21.0",
        "typescript": "~5.9.3",
        "typescript-eslint": "^8.57.0",
        "vite": "^8.0.0",
        "vite-plugin-electron": "^0.29.0",
        "vitest": "^4.1.0",
        "yaml": "^2.8.2"
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "electron",
            "electron-winstaller",
            "esbuild",
            "unrs-resolver"
        ],
        "overrides": {
            "@typescript-eslint/utils": "8.57.0"
        },
        "patchedDependencies": {
            "@rolldown/plugin-babel": "patches/@rolldown__plugin-babel.patch"
        }
    }
}
